 /*
+ * Collapse only the first five instructions of the same division loop:
+ *   PUSH AF / RL L / RL H / RL C / RL B
+ *
+ * This 48-cycle block is much easier to fit before the next LCD or timer
+ * boundary than the complete 144-160 cycle iteration. Execution resumes at
+ * 0x23D7 (PUSH BC), so all remaining instructions retain normal interrupt
+ * and timing granularity.
+ */
+static uint_fast16_t
+__gb_div_prefix_fast(struct gb_s *gb)
+{
+    uint8_t carry;
+    uint8_t old_value;
+
+    PGB_STACK_PUSH8(gb, gb->cpu_reg.a);
+    PGB_STACK_PUSH8(gb, gb->cpu_reg.f);
+
+    carry = (gb->cpu_reg.f & PGB_FLAG_C) ? 1 : 0;
+
+    old_value = gb->cpu_reg.hl.bytes.l;
+    gb->cpu_reg.hl.bytes.l =
+        (uint8_t)((old_value << 1) | carry);
+    carry = (uint8_t)(old_value >> 7);
+
+    old_value = gb->cpu_reg.hl.bytes.h;
+    gb->cpu_reg.hl.bytes.h =
+        (uint8_t)((old_value << 1) | carry);
+    carry = (uint8_t)(old_value >> 7);
+
+    old_value = gb->cpu_reg.bc.bytes.c;
+    gb->cpu_reg.bc.bytes.c =
+        (uint8_t)((old_value << 1) | carry);
+    carry = (uint8_t)(old_value >> 7);
+
+    old_value = gb->cpu_reg.bc.bytes.b;
+    gb->cpu_reg.bc.bytes.b =
+        (uint8_t)((old_value << 1) | carry);
+    carry = (uint8_t)(old_value >> 7);
+
+    /* Flags left by CB 10 (RL B). */
+    gb->cpu_reg.f =
+        (uint8_t)((gb->cpu_reg.bc.bytes.b == 0 ? PGB_FLAG_Z : 0) |
+        (carry ? PGB_FLAG_C : 0));
+
+    gb->cpu_reg.pc.reg = 0x23D7;
+    return 48;
+}
+
+
+/*
+ * Collapse the fixed epilogue at 0x23F2:
+ *   LD D,B / LD E,C / RL L / LD C,L / RL H / LD B,H / OR A / RET
+ *
+ * The current carry flag is an input to RL L and therefore must be preserved
+ * until the first shift. The helper reproduces the final registers, flags,
+ * stack pointer and return address in 52 guest cycles.
+ */
+static uint_fast16_t
+__gb_div_final_fast(struct gb_s *gb)
+{
+    uint8_t carry;
+    uint8_t old_value;
+
+    gb->cpu_reg.de.bytes.d = gb->cpu_reg.bc.bytes.b;
+    gb->cpu_reg.de.bytes.e = gb->cpu_reg.bc.bytes.c;
+
+    carry = (gb->cpu_reg.f & PGB_FLAG_C) ? 1 : 0;
+
+    old_value = gb->cpu_reg.hl.bytes.l;
+    gb->cpu_reg.hl.bytes.l =
+        (uint8_t)((old_value << 1) | carry);
+    carry = (uint8_t)(old_value >> 7);
+    gb->cpu_reg.bc.bytes.c = gb->cpu_reg.hl.bytes.l;
+
+    old_value = gb->cpu_reg.hl.bytes.h;
+    gb->cpu_reg.hl.bytes.h =
+        (uint8_t)((old_value << 1) | carry);
+    gb->cpu_reg.bc.bytes.b = gb->cpu_reg.hl.bytes.h;
+
+    /* OR A: A is unchanged; Z follows A, N/H/C are cleared. */
+    gb->cpu_reg.f =
+        (gb->cpu_reg.a == 0) ? PGB_FLAG_Z : 0;
+
+    gb->cpu_reg.pc.bytes.c = PGB_STACK_POP8(gb);
+    gb->cpu_reg.pc.bytes.p = PGB_STACK_POP8(gb);
+
+    return 52;
+}
